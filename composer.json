{
    "name": "bit-es/google-translate",
    "description": "Google Translate package for use in Laravel Filament.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "BIT Ecosystem",
            "email": "bit.ecosystem@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "bit-es/base": "^1.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Bites\\GoogleTranslate\\GoogleTranslateServiceProvider"
            ]
        }
    },
    "autoload": {
        "psr-4": {
            "Bites\\GoogleTranslate\\": "src/"
        }
    },
    "minimum-stability": "alpha",
    "prefer-stable": true
}